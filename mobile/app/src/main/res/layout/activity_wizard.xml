<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f8fafc"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Booking Details"
            android:textColor="#0f172a"
            android:textSize="24sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="24dp" />

        <!-- Service Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Your Service"
            android:textColor="#334155"
            android:textSize="16sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            
            <!-- Self Service Card -->
            <LinearLayout
                android:id="@+id/cardSelfService"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_wizard_card_selected"
                android:padding="16dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱250"
                    android:textColor="#0f172a"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Self-Service"
                    android:textColor="#475569"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Full Service Card -->
            <LinearLayout
                android:id="@+id/cardFullService"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_wizard_card_default"
                android:padding="16dp"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱350"
                    android:textColor="#0f172a"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Service"
                    android:textColor="#475569"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Vehicle Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vehicle Scale Selection"
            android:textColor="#334155"
            android:textSize="16sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">
            
            <!-- 4 Seater Card -->
            <LinearLayout
                android:id="@+id/card4Seater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_wizard_card_selected"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Small Scale"
                        android:textColor="#0f172a"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-black" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4-Seater Sedans &amp; Hatchbacks"
                        android:textColor="#94a3b8"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
                
                <TextView
                    android:id="@+id/tvSur4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+₱100"
                    android:textColor="#2563eb"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black" />
            </LinearLayout>

            <!-- 7 Seater Card -->
            <LinearLayout
                android:id="@+id/card7Seater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_wizard_card_default"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Medium Scale"
                        android:textColor="#0f172a"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-black" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7-Seater SUVs &amp; MPVs"
                        android:textColor="#94a3b8"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
                
                <TextView
                    android:id="@+id/tvSur7"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+₱130"
                    android:textColor="#2563eb"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black" />
            </LinearLayout>
            
            <!-- Max Seater Card -->
            <LinearLayout
                android:id="@+id/cardMaxSeater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_wizard_card_default"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Large Scale"
                        android:textColor="#0f172a"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-black" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vans &amp; Trucks (>7 Seaters)"
                        android:textColor="#94a3b8"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
                
                <TextView
                    android:id="@+id/tvSurMax"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+₱160"
                    android:textColor="#2563eb"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#e2e8f0"
            android:layout_marginBottom="24dp" />
            
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Date &amp; Time:"
                android:textColor="#64748b"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tvDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2023-10-25 08:00 AM"
                android:textColor="#0f172a"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total Amount:"
                android:textColor="#64748b"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black" />
            <TextView
                android:id="@+id/tvTotalAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱350"
                android:textColor="#2563eb"
                android:textSize="26sp"
                android:fontFamily="sans-serif-black" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Confirm Booking"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            app:backgroundTint="#2563eb" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Cancel"
            android:textColor="#64748b"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
