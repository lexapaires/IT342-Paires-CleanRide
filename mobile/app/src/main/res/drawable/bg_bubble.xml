<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <!-- 5% opacity white border -->
    <stroke android:width="1dp" android:color="#0DFFFFFF" />
    
    <!-- Slight white radial gradient simulating bubble shine -->
    <gradient
        android:type="radial"
        android:centerX="0.3"
        android:centerY="0.3"
        android:gradientRadius="50%p"
        android:startColor="#1AFFFFFF"
        android:endColor="#03FFFFFF" />
</shape>
