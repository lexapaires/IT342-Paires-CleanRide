<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected State -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/primary_blue_600" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    
    <!-- Default State -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_slate_50" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="@color/slot_disabled" />
        </shape>
    </item>
</selector>
